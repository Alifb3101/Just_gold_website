
{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://just-gold-backend-render.onrender.com/sitemap.xml"
    },
    {
      "source": "/sitemap-products.xml",
      "destination": "https://just-gold-backend-render.onrender.com/sitemap-products.xml"
    },
    {
      "source": "/sitemap-categories.xml",
      "destination": "https://just-gold-backend-render.onrender.com/sitemap-categories.xml"
    },
    {
      "source": "/sitemap-pages.xml",
      "destination": "https://just-gold-backend-render.onrender.com/sitemap-pages.xml"
    },
    {
      "source": "/api/:path*",
      "destination": "http://localhost:5000/api/v1/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://localhost:5000/uploads/:path*"
    },
    {
      "source": "/((?!api|_next|static|sitemap.xml|robots.txt|favicon.ico|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/sitemap-products.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/sitemap-categories.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/sitemap-pages.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
